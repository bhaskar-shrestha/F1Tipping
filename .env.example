# F1 Tipping App - Environment Configuration

# Backend API Port (optional, defaults to 8080)
# Used when running backend directly with: PORT=8080 go run src/main.go
# For docker, use: docker-compose up
API_PORT=8080

# Backend Host (optional, defaults to localhost)
# Used when running outside Docker
API_HOST=localhost

# API Base URL for UI client (optional)
# Set this if backend is on different host
API_BASE_URL=http://localhost:8080
